{
  "version": 2,
  "builds": [
    {
      "src": "api/trainees.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/trainees/[id].js",
      "use": "@vercel/node"
    },
    {
      "src": "api/submissions.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/submissions/[id].js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.md",
      "use": "@vercel/static"
    },
    {
      "src": "*.sql",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/trainees",
      "dest": "/api/trainees.js"
    },
    {
      "src": "/api/trainees/([^/]+)",
      "dest": "/api/trainees/[id].js?id=$1"
    },
    {
      "src": "/api/submissions",
      "dest": "/api/submissions.js"
    },
    {
      "src": "/api/submissions/([^/]+)",
      "dest": "/api/submissions/[id].js?id=$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
